{
  "name": "full_cuda24_qwen05b_v1",
  "description": "Full fine-tune for CUDA server with ~24GB VRAM.",
  "script": "scripts/train_full_sft.py",
  "args": {
    "dataset": "data/processed/sft_full_mix_v1_11k5.jsonl",
    "model": "Qwen/Qwen2.5-0.5B-Instruct",
    "output": "data/models/full-qwen05b-report-v1",
    "epochs": 1,
    "batch-size": 2,
    "max-length": 384,
    "max-steps": 240,
    "learning-rate": 2e-5,
    "weight-decay": 0.01,
    "gradient-accumulation-steps": 4,
    "warmup-steps": 30,
    "save-steps": 60,
    "eval-ratio": 0.05,
    "seed": 42,
    "gradient-checkpointing": true
  }
}
