{
  "name": "full_smoke_distilgpt2",
  "description": "Very fast smoke profile to validate pipeline end-to-end.",
  "script": "scripts/train_full_sft.py",
  "args": {
    "dataset": "data/processed/sft_dataset.jsonl",
    "model": "distilgpt2",
    "output": "data/models/full-distilgpt2-smoke",
    "epochs": 1,
    "batch-size": 1,
    "max-length": 128,
    "max-steps": 20,
    "learning-rate": 5e-5,
    "weight-decay": 0.0,
    "gradient-accumulation-steps": 4,
    "warmup-steps": 5,
    "save-steps": 10,
    "eval-ratio": 0.0,
    "seed": 42,
    "gradient-checkpointing": false
  }
}
